#!/usr/bin/python3 -S
"""Linux-Router-Monitor :: desktop-side collector.

Invoked by the plasmoids once per poll. Guarantees the router is hit at most
once per interval no matter how many widgets are running:

  * a single persistent SSH ControlMaster socket is shared by every call;
  * a flock'd JSON cache in $XDG_RUNTIME_DIR is refreshed by the first widget
    to tick in each interval -- everyone else just reads the fresh snapshot.

Usage:  routermon-collect [section]
        section = all (default) | system | network | wifi | dns | clients | info

Prints the requested section of the latest snapshot as JSON on stdout.
"""
import fcntl
import json
import os
import sys
import time
# subprocess / urllib / base64 are imported lazily inside the refresh + AdGuard
# paths only, so the common cache-read path starts a near-empty interpreter.

APP = "Linux-Router-Monitor"
CONFIG = os.path.expanduser(f"~/.config/{APP}/config.json")
RUNDIR = os.path.join(os.environ.get("XDG_RUNTIME_DIR", "/tmp"), APP)
CACHE = os.path.join(RUNDIR, "data.json")
STATE = os.path.join(RUNDIR, "state.json")
LOCK = os.path.join(RUNDIR, "refresh.lock")
SOCK = os.path.join(RUNDIR, "cm.sock")
PAUSE = os.path.join(RUNDIR, "paused")
LOGDIR = os.path.expanduser(f"~/.local/state/{APP}")
LOG = os.path.join(LOGDIR, "monitor.log")


def log(msg):
    try:
        os.makedirs(LOGDIR, exist_ok=True)
        # keep the log small (cap ~256 KiB)
        if os.path.exists(LOG) and os.path.getsize(LOG) > 262144:
            with open(LOG) as f:
                tail = f.readlines()[-1000:]
            with open(LOG, "w") as f:
                f.writelines(tail)
        with open(LOG, "a") as f:
            f.write(f"{time.strftime('%Y-%m-%d %H:%M:%S')}  {msg}\n")
    except OSError:
        pass


def load_config():
    with open(CONFIG) as f:
        return json.load(f)


def ssh_base(cfg):
    key = os.path.expanduser(cfg.get("ssh_key", "~/.ssh/id_ed25519"))
    return [
        "ssh",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=6",
        "-o", "ControlMaster=auto",
        "-o", f"ControlPath={SOCK}",
        "-o", f"ControlPersist={cfg.get('control_persist', '60')}",
        "-o", "StrictHostKeyChecking=accept-new",
        "-i", key,
        f"{cfg.get('user', 'admin')}@{cfg['host']}",
    ]


def fetch_remote(cfg, do_ping=True, do_slow=True, do_static=False):
    import subprocess
    # args: ping_target, do_ping, do_slow, do_static
    cmd = ssh_base(cfg) + [
        f"sh {cfg.get('remote_script', '/jffs/lrm-collect.sh')} "
        f"{cfg.get('ping_target', '8.8.8.8')} {1 if do_ping else 0} "
        f"{1 if do_slow else 0} {1 if do_static else 0}"
    ]
    out = subprocess.run(cmd, capture_output=True, text=True, timeout=20)
    if out.returncode != 0 or "END=1" not in out.stdout:
        raise RuntimeError(f"remote collect failed rc={out.returncode}: {out.stderr.strip()[:200]}")
    return out.stdout


def parse_remote(raw):
    d = {"radios": [], "radios_static": [], "stations": [], "stations_slow": [],
         "leases": [], "ifaces": {}, "ports": [], "arp": [], "blocked": [],
         "rcount": [], "_stat": {}}
    for line in raw.splitlines():
        if not line:
            continue
        if line.startswith("STAT "):
            parts = line.split()
            d["_stat"][parts[1]] = [int(x) for x in parts[2:]]
        elif line.startswith("IF "):
            _, name, rx, tx = line.split()
            d["ifaces"][name] = {"rx": int(rx), "tx": int(tx)}
        elif line.startswith("PORT "):
            p = line.split(maxsplit=2)
            d["ports"].append({"port": p[1], "link": p[2]})
        elif line.startswith("RADIO "):
            d["radios"].append(_kv(line[6:]))
        elif line.startswith("RSTATIC "):
            d["radios_static"].append(_kv(line[8:]))
        elif line.startswith("RCOUNT "):
            d["rcount"].append(_kv(line[7:]))
        elif line.startswith("STA "):
            d["stations"].append(_kv(line[4:]))
        elif line.startswith("STASLOW "):
            d["stations_slow"].append(_kv(line[8:]))
        elif line.startswith("LEASE "):
            d["leases"].append(_kv(line[6:]))
        elif line.startswith("ARP "):
            parts = line.split()
            d["arp"].append({"mac": parts[1], "flags": parts[2] if len(parts) > 2 else "0x0"})
        elif line.startswith("BLOCKED "):
            d["blocked"].append(line.split()[1])
        elif "=" in line:
            k, v = line.split("=", 1)
            d[k] = v
    return d


def _kv(s):
    out = {}
    for tok in s.split():
        if "=" in tok:
            k, v = tok.split("=", 1)
            out[k] = v
        else:  # value contained spaces (e.g. ssid) -> append to last key
            if out:
                out[list(out)[-1]] += " " + tok
    return out


def _toplist(items, limit=6):
    """AGH top lists are [{"name": count}, ...] -> [{"name":..,"count":..}]."""
    out = []
    for it in (items or [])[:limit]:
        if isinstance(it, dict) and it:
            k = next(iter(it))
            out.append({"name": k, "count": it[k]})
    return out


def _num(v, cast=float, default=0):
    try:
        return cast(v)
    except (TypeError, ValueError):
        return default


def cpu_util(stat, prev):
    """Return {'total': pct, 'cores': [pct,...]} from successive /proc/stat."""
    res = {"cores": []}

    def pct(cur, old):
        if not old:
            return 0.0
        dt = sum(cur) - sum(old)
        di = (cur[3] + cur[4]) - (old[3] + old[4])  # idle + iowait
        return round(100.0 * (dt - di) / dt, 1) if dt > 0 else 0.0

    res["total"] = pct(stat.get("cpu", []), prev.get("cpu", []))
    i = 0
    while f"cpu{i}" in stat:
        res["cores"].append(pct(stat[f"cpu{i}"], prev.get(f"cpu{i}", [])))
        i += 1
    return res


def rate(cur, old, dt):
    if old is None or dt <= 0 or cur < old:
        return 0.0
    return (cur - old) / dt


def fetch_agh(cfg):
    import base64
    import urllib.error
    import urllib.request
    a = cfg.get("adguard", {})
    if not a.get("enabled"):
        return None
    base = a["url"].rstrip("/")
    hdr = {}
    if a.get("username"):
        tok = base64.b64encode(f"{a['username']}:{a.get('password','')}".encode()).decode()
        hdr["Authorization"] = f"Basic {tok}"
    out = {}
    for ep, key in (("/control/stats", "stats"), ("/control/status", "status")):
        try:
            req = urllib.request.Request(base + ep, headers=hdr)
            with urllib.request.urlopen(req, timeout=5) as r:
                out[key] = json.load(r)
        except (urllib.error.URLError, ValueError, OSError) as e:
            log(f"AGH {ep} failed: {e}")
            out[key] = None
    return out


def build(cfg, prev):
    # Three cadences: FAST (every poll) = CPU/throughput/per-client signal+traffic;
    # SLOW (every slow_every) = nvram statics, per-radio meta, leases, firewall;
    # PING + AdGuard, even less often. Slow/ping/agh values are carried forward.
    tick = int(prev.get("tick", 0)) + 1
    slow_every = max(1, int(cfg.get("slow_every", 10)))
    do_slow = (prev.get("slow") is None) or (tick % slow_every == 0)
    # Ping and AdGuard are fetched by the caller (serve) so their latency
    # (~2.6s and ~0.6s) never blocks the fast snapshot. build() carries both.
    prev_ping = prev.get("ping") or {}

    raw = fetch_remote(cfg, False, do_slow)
    p = parse_remote(raw)
    now = _num(p.get("TS"), float, time.time())
    dt = now - prev.get("ts", now) if prev else 0

    ping_rtt = prev_ping.get("rtt", 0)
    ping_loss = prev_ping.get("loss", 0)

    # ---- FAST: throughput, cpu, per-station signal/traffic ----
    ifr = {}
    for name, c in p["ifaces"].items():
        po = (prev.get("ifaces") or {}).get(name)
        ifr[name] = {
            "rx_bps": rate(c["rx"], po["rx"] if po else None, dt),
            "tx_bps": rate(c["tx"], po["tx"] if po else None, dt),
        }
    wan_if = p.get("wan_ifname", "ppp0")
    wan = ifr.get(wan_if, {"rx_bps": 0, "tx_bps": 0})
    cpu = cpu_util(p["_stat"], prev.get("stat", {}))

    # Per-client signal + link rates change slowly, so they ride the slow tick
    # (one sta_info per client) and are carried forward; the fast tick only does
    # the bulk `wl bs_data` (one call per radio) for live throughput.
    if do_slow and p.get("stations_slow"):
        sta_slow = {}
        for s in p["stations_slow"]:
            sta_slow[s.get("mac", "").lower()] = {
                "rssi": _num(s.get("rssi"), int),
                "tx_mbps": round(_num(s.get("txrate")) / 1000.0, 1),
                "rx_mbps": round(_num(s.get("rxrate")) / 1000.0, 1),
            }
    else:
        sta_slow = prev.get("sta_slow") or {}

    stations = []
    for s in p["stations"]:
        mac = s.get("mac", "")
        sl = sta_slow.get(mac.lower(), {})
        stations.append({
            "mac": mac, "band": s.get("band"),
            "rssi": sl.get("rssi", 0),
            "tx_mbps": sl.get("tx_mbps", 0),
            "rx_mbps": sl.get("rx_mbps", 0),
            "phy_mbps": round(_num(s.get("phy")), 0),
            # bs_data reports live throughput in Mbit/s -> bytes/s for traffic_bps
            "traffic_bps": round(_num(s.get("data_mbps")) * 125000.0, 0),
        })
    wifi_macs = {s.get("mac", "").lower() for s in p["stations"]}
    sta_traffic = {s["mac"].lower(): s["traffic_bps"] for s in stations}
    rcount = {r.get("band"): _num(r.get("clients"), int) for r in p["rcount"]}

    mt = _num(p.get("mem_total"), int); ma = _num(p.get("mem_avail"), int)
    st = _num(p.get("swap_total"), int); sf = _num(p.get("swap_free"), int)

    # ---- SLOW: dynamic statics/meta (every slow tick), or carry forward ----
    if do_slow:
        slow = {
            "wan": {
                "wan_proto": p.get("wan_proto"), "wan_ip": p.get("wan_ip"),
                "wan_gw": p.get("wan_gw"), "wan_dns": p.get("wan_dns"),
                "wan_up": p.get("wan_state") == "2",
            },
            "radios": [{
                "band": r.get("band"),
                "chan": _num(r.get("chan"), int), "width": r.get("width"),
                "noise": _num(r.get("noise"), int),
                "temp": _num(r.get("temp"), int), "busy": _num(r.get("busy"), int),
                "glitch": _num(r.get("glitch"), int), "badplcp": _num(r.get("badplcp"), int),
                "dfs": r.get("dfs"),
            } for r in p["radios"]],
            "leases": [{"mac": l.get("mac"), "ip": l.get("ip"),
                        "name": (l.get("name") if l.get("name") != "*" else l.get("ip"))}
                       for l in p["leases"]],
            "arp_up": sorted({a["mac"].lower() for a in p["arp"] if a.get("flags") != "0x0"}),
            "blocked": sorted({m.lower() for m in p["blocked"]}),
            "security": {"wrs_protect": p.get("wrs_protect") == "1",
                         "wrs_mals": p.get("wrs_mals") == "1"},
        }
    else:
        slow = prev.get("slow") or {}

    # STATIC: identity + ssid/radio/txpower + ports, refetched only on reconnect
    static = prev.get("static_cache") or {}
    static_radios = static.get("radios", {})

    online = set(slow.get("arp_up", [])) | wifi_macs
    blocked = set(slow.get("blocked", []))
    radios = []
    for r in slow.get("radios", []):
        band = r.get("band")
        radios.append({**static_radios.get(band, {}), **r, "clients": rcount.get(band, 0)})
    leases = [{**l, "connected": (l.get("mac", "").lower() in online),
               "blocked": (l.get("mac", "").lower() in blocked),
               "traffic_bps": sta_traffic.get(l.get("mac", "").lower(), -1)}
              for l in slow.get("leases", [])]

    # AdGuard is fetched separately (see serve / compute_dns); carry it here
    dns = prev.get("dns_cache")

    snap = {
        "ts": now,
        "online": True,
        "paused": False,
        "info": {**static.get("info", {}),
                 "admin_url": ("http://" + static["info"]["lan_ip"])
                              if static.get("info", {}).get("lan_ip") else "",
                 "agh_url": cfg.get("adguard", {}).get("url", ""),
                 "uptime": _num(p.get("uptime"), float)},
        "system": {
            "cpu": cpu,
            "load": [_num(p.get("load1")), _num(p.get("load5")), _num(p.get("load15"))],
            "procs": p.get("procs"), "cores": _num(p.get("cores"), int),
            "mem_total": mt, "mem_avail": ma,
            "mem_used_pct": round(100.0 * (mt - ma) / mt, 1) if mt else 0.0,
            "swap_total": st, "swap_used": st - sf,
            "swap_used_pct": round(100.0 * (st - sf) / st, 1) if st else 0.0,
            "cpu_temp": round(_num(p.get("cpu_temp_milli")) / 1000.0, 1),
            "conntrack": _num(p.get("conntrack"), int),
            "conntrack_max": _num(p.get("conntrack_max"), int),
        },
        "network": {
            **slow.get("wan", {}),
            "down_mbps": round(wan["rx_bps"] * 8 / 1e6, 2),
            "up_mbps": round(wan["tx_bps"] * 8 / 1e6, 2),
            "ping_rtt": ping_rtt, "ping_loss": ping_loss,
            "ports": static.get("ports", []),
            "ifaces": {k: {
                "rx_mbps": round(ifr[k]["rx_bps"] * 8 / 1e6, 2),
                "tx_mbps": round(ifr[k]["tx_bps"] * 8 / 1e6, 2),
            } for k in ("br0", wan_if) if k in ifr},
        },
        "wifi": {"radios": radios, "stations": stations},
        "clients": {"count": len(leases), "leases": leases},
        "dns": dns,
        "security": slow.get("security", {}),
    }
    new_state = {"ts": now, "stat": p["_stat"], "ifaces": p["ifaces"], "sta_slow": sta_slow,
                 "tick": tick, "ping": {"rtt": ping_rtt, "loss": ping_loss},
                 "dns_cache": dns, "agh_prev": prev.get("agh_prev") or {}, "slow": slow,
                 "static_cache": static}
    return snap, new_state


def compute_static(cfg):
    """Router identity + ssid/radio/txpower + wired ports. These change only on
    reconfiguration (which drops the connection), so we refetch them only when the
    router transitions offline -> online, not on a timer."""
    p = parse_remote(fetch_remote(cfg, do_ping=False, do_slow=False, do_static=True))
    return {
        "info": {"model": p.get("model"), "fw": p.get("fw"), "lan_ip": p.get("lan_ip")},
        "ports": [pt for pt in p["ports"] if "Up" in pt["link"]] or p["ports"],
        "radios": {r.get("band"): {"ssid": r.get("ssid"), "on": r.get("radio") == "1",
                                   "txpower": _num(r.get("txpower"), int)}
                   for r in p.get("radios_static", [])},
    }


def compute_ping(cfg):
    """WAN latency via the router (~2.6s). Separate from build() so it never
    blocks the fast snapshot."""
    import re
    import subprocess
    cmd = ssh_base(cfg) + [f"ping -c 3 -w 4 {cfg.get('ping_target', '8.8.8.8')}"]
    try:
        out = subprocess.run(cmd, capture_output=True, text=True, timeout=15).stdout
    except (OSError, subprocess.SubprocessError):
        return None
    m = re.search(r"=\s*[\d.]+/([\d.]+)/", out)
    if not m:
        return None
    loss = re.search(r"(\d+)% packet loss", out)
    return {"rtt": round(float(m.group(1)), 1), "loss": int(loss.group(1)) if loss else 0}


def compute_dns(cfg, agh_prev, leases, now):
    """Fetch AdGuard stats and build the dns block. Separate from build() so its
    ~0.6s latency runs on the medium tick without delaying the fast snapshot."""
    agh = fetch_agh(cfg)
    if not (agh and agh.get("stats")):
        return None, agh_prev
    s = agh["stats"]
    q = _num(s.get("num_dns_queries"), int)
    b = _num(s.get("num_blocked_filtering"), int)
    adt = now - agh_prev.get("ts", now)
    dns = {
        "queries_total": q, "blocked_total": b,
        "blocked_pct": round(100.0 * b / q, 1) if q else 0.0,
        "qps": round(rate(q, agh_prev.get("q"), adt), 1),
        "avg_ms": round(_num(s.get("avg_processing_time")) * 1000, 1),
        "malware": _num(s.get("num_replaced_safebrowsing"), int),
        "parental": _num(s.get("num_replaced_parental"), int),
        "top_queried": _toplist(s.get("top_queried_domains")),
        "top_blocked": _toplist(s.get("top_blocked_domains")),
        "top_clients": _toplist(s.get("top_clients")),
        "protection": (agh.get("status") or {}).get("protection_enabled"),
        "url": cfg.get("adguard", {}).get("url", ""),
        # AdGuard's own time-series (per time_unit) — plot it directly
        "history": s.get("dns_queries") or [],
        "history_blocked": s.get("blocked_filtering") or [],
        "time_units": s.get("time_units"),
    }
    ip2name = {l.get("ip"): l.get("name") for l in leases}
    for c in dns["top_clients"]:
        c["name"] = ip2name.get(c["name"], c["name"])
    return dns, {"q": q, "ts": now}


def refresh(cfg):
    try:
        prev = json.load(open(STATE)) if os.path.exists(STATE) else {}
    except (ValueError, OSError):
        prev = {}
    try:
        sc = compute_static(cfg)
        if sc:
            prev["static_cache"] = sc
        snap, state = build(cfg, prev)
        dns, state["agh_prev"] = compute_dns(cfg, state.get("agh_prev") or {},
                                             snap["clients"]["leases"], snap["ts"])
        if dns is not None:
            snap["dns"] = dns
            state["dns_cache"] = dns
        pg = compute_ping(cfg)
        if pg is not None:
            state["ping"] = pg
            snap["network"]["ping_rtt"] = pg["rtt"]
            snap["network"]["ping_loss"] = pg["loss"]
    except Exception as e:
        log(f"refresh error: {e}")
        snap = {"ts": time.time(), "online": False, "error": str(e)}
        state = prev
    _atomic_write(CACHE, snap)
    _atomic_write(STATE, state)
    return snap


def _merge_static(snap, sc, cfg):
    """Fold a freshly-fetched static block into an already-built snapshot."""
    info = dict(sc.get("info") or {})
    info["admin_url"] = ("http://" + info["lan_ip"]) if info.get("lan_ip") else ""
    info["agh_url"] = cfg.get("adguard", {}).get("url", "")
    info["uptime"] = (snap.get("info") or {}).get("uptime", 0)
    snap["info"] = info
    snap.setdefault("network", {})["ports"] = sc.get("ports", [])
    sr = sc.get("radios", {})
    for r in (snap.get("wifi") or {}).get("radios", []):
        r.update(sr.get(r.get("band"), {}))


def _atomic_write(path, obj):
    tmp = path + ".tmp"
    with open(tmp, "w") as f:
        json.dump(obj, f)
    os.replace(tmp, path)


def serve():
    """Resident mode: one long-lived process that keeps the cache fresh, so the
    widgets never have to spawn anything (they read the cache file in-process).
    Run as a systemd --user service."""
    os.makedirs(RUNDIR, exist_ok=True)
    lk = open(os.path.join(RUNDIR, "serve.lock"), "w")
    try:
        fcntl.flock(lk, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        return  # another server is already running
    prev = {}
    was_online = False
    while True:
        start = time.monotonic()
        try:
            cfg = load_config()
        except (ValueError, OSError):
            time.sleep(2)
            continue
        interval = float(cfg.get("poll_interval", 0.5))
        if os.path.exists(PAUSE):
            try:
                data = json.load(open(CACHE))
            except (ValueError, OSError):
                data = {"online": True}
            data["paused"] = True
            _atomic_write(CACHE, data)
        else:
            ok = True
            try:
                snap, prev = build(cfg, prev)
            except Exception as e:
                log(f"serve error: {e}")
                snap = {"ts": time.time(), "online": False, "error": str(e), "paused": False}
                ok = False
            _atomic_write(CACHE, snap)   # fast data written first (never blocked)
            # RECONNECT (incl. first connect): router went offline -> online, so
            # refetch the static identity/config (model/fw/ssid/radio/txpower/ports)
            now_online = ok and snap.get("online") is not False
            if now_online and not was_online:
                try:
                    sc = compute_static(cfg)
                except Exception as e:
                    log(f"static fetch failed: {e}")
                    sc = None
                if sc:
                    prev["static_cache"] = sc
                    _merge_static(snap, sc, cfg)
                    _atomic_write(CACHE, snap)
            was_online = now_online
            # SLOW tick: AdGuard (~0.6s) + WAN ping (~2.6s), each fetched after the
            # fast write and written separately so they never block fast data
            slow_every = max(1, int(cfg.get("slow_every", 10)))
            tick = prev.get("tick", 0)
            slow_due = tick == 1 or tick % slow_every == 0
            if ok and (prev.get("dns_cache") is None or slow_due):
                dns, prev["agh_prev"] = compute_dns(
                    cfg, prev.get("agh_prev") or {},
                    snap.get("clients", {}).get("leases", []), snap.get("ts", time.time()))
                if dns is not None:
                    snap["dns"] = dns
                    prev["dns_cache"] = dns
                    _atomic_write(CACHE, snap)
            if ok and slow_due:
                pg = compute_ping(cfg)
                if pg is not None:
                    prev["ping"] = pg
                    snap.setdefault("network", {})["ping_rtt"] = pg["rtt"]
                    snap["network"]["ping_loss"] = pg["loss"]
                    _atomic_write(CACHE, snap)
        # subtract the work time so each cycle is ~interval, not interval + work
        time.sleep(max(0.0, interval - (time.monotonic() - start)))


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "--serve":
        serve()
        return

    section = sys.argv[1] if len(sys.argv) > 1 else "all"
    os.makedirs(RUNDIR, exist_ok=True)

    # Global pause: serve the last snapshot (flagged paused), don't touch the router
    if os.path.exists(PAUSE):
        try:
            data = json.load(open(CACHE))
        except (ValueError, OSError):
            data = {"online": True}
        data["paused"] = True
        print(json.dumps(data if section == "all" or section not in data else data[section]))
        return

    cfg = load_config()
    ttl = float(cfg.get("cache_ttl", 1.8))

    fresh = os.path.exists(CACHE) and (time.time() - os.path.getmtime(CACHE)) < ttl
    if not fresh:
        with open(LOCK, "w") as lk:
            fcntl.flock(lk, fcntl.LOCK_EX)
            # re-check: another widget may have refreshed while we waited
            if not (os.path.exists(CACHE) and (time.time() - os.path.getmtime(CACHE)) < ttl):
                refresh(cfg)

    try:
        data = json.load(open(CACHE))
    except (ValueError, OSError):
        data = {"online": False, "error": "no data"}

    if section != "all" and section in data:
        print(json.dumps(data[section]))
    else:
        print(json.dumps(data))


if __name__ == "__main__":
    main()
